# =============================================================================
# 阿里云 OSS 部署配置文件
# =============================================================================
# 复制此文件为 env.oss，填入真实值后即可运行 deploy-oss.sh
#   cp scripts/env.oss.example scripts/env.oss
#
# 安全提醒: env.oss 已被 .gitignore 排除，不会提交到 Git
# =============================================================================

# ---------- 必填 ----------
# OSS Bucket 名称（全局唯一）
OSS_BUCKET=my-ai-site
# OSS 地域代码（如 oss-cn-hangzhou / oss-cn-beijing / oss-cn-shanghai）
OSS_REGION=oss-cn-hangzhou
# OSS 外网 Endpoint
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ---------- 可选：缓存策略 ----------
# HTML 文件缓存（推荐不缓存，确保更新即时生效）
CACHE_CONTROL_HTML=no-cache
# 静态资源缓存（JS/CSS/图片带 hash，可永久缓存）
CACHE_CONTROL_ASSETS=public,max-age=31536000,immutable

# ---------- 可选：CDN ----------
# 自定义域名（与 CDN 绑定）
# CDN_DOMAIN=www.example.com
# 部署后需要刷新的 CDN 路径（通常为根目录）
# CDN_REFRESH_PATH=http://www.example.com/
